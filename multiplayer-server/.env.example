PORT=8787
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Allowed frontend origins (comma-separated)
APP_ORIGIN=https://personfu.github.io,https://fllc.net

# ═══ DATABASE ═══
# Supabase PostgreSQL (recommended):
#   Get connection string from Supabase Dashboard → Settings → Database → Connection String (URI)
# Railway PostgreSQL:
#   Get from Railway dashboard → your Postgres service → Variables → DATABASE_URL
# Leave empty to use local db.json file (dev only)
DATABASE_URL=

# ═══ STRIPE BILLING ═══
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Create at https://dashboard.stripe.com/webhooks — endpoint: POST /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Create a product+price at https://dashboard.stripe.com/products
STRIPE_PRICE_ID=
